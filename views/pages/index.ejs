<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="stylesheet" href="assets/css/menu.css">
    
</head>

<body>
    <!-- <img src="/assets/images/logo.png" alt="Ishare logo" class="logo"> -->
        <!-- Button trigger modal -->
    
    <section class="upload-container">
        <form enctype="multipart/form-data" action="/api/UploadFiles" method="post" name="file_upload_form" id="file_upload_form">
            
            <div class="drop-zone">
                <div class="icon-container">
                    <img src="/assets/images/file.svg" draggable="false" class="center" alt="File Icon">
                    <img src="/assets/images/file.svg" draggable="false" class="left" alt="File Icon">
                    <img src="/assets/images/file.svg" draggable="false" class="right" alt="File Icon">
                </div>
                <!-- <div class="progressBar">
                    <div class="bar"></div>
                    <div class="percent"></div>
                </div> --->
                <input type="file" id="fileInput" name="upload_file">
                <div class="title">Drop your Files here or, <span id="browseBtn">browse</span></div>
            </div>
        </form>
        <!--------Progress Bar----------->
        <div class="progress-container">
            <div class="progressBar">
                <div class="bar"></div>
                <div class="percent"></div>
            </div>

            <div class="inner-container">
                <div class="status">Uploading...</div>
                <div class="percent-container">
                    <span class="percentage" id="progressPercent">0</span>%
                </div>
                <div class="progress-bar"></div>
            </div>
        </div>
        <!--------Progress Bar END----------->

        <div class="sharing-container">
            <p class="expire">Link expires in 24 hrs</p>


            <div class="input-container">
                <input type="text" id="fileURL" readonly>
                <img src="/assets/images/copy-icon.svg" id="copyURLBtn" alt="copy to clipboard icon" onclick="copy()">
            </div>

            <p class="email-info">Or Send via Email</p>
            <div class="email-container">
                <form method="post" action="/mailsend" id="emailForm">
                    <div class="filed">
                        <label for="fromEmail">Your email</label>
                        <input type="email" autocomplete="email" required name="emailFrom" id="fromEmail" >
                    </div>

                    <div class="filed">
                        <label for="toEmail">Receiver's email</label>
                        <input type="email" required autocomplete="receiver" name="emailTo" id="toEmail">
                    </div>
                    <div class="filed">
                        <label for="toEmail">Message</label>
                        <textarea id="message" name="message" cols="23" rows="1" placeholder="Write a message..." name="message"></textarea>
                    </div>
                    <div class="send-btn-container">
                        <button type="submit">Send</button>
                    </div>
                </form>
            </div>
        </div>
    </section>
    <div class="image-vector" id="toast1"></div>
    <div class="toast" ></div>

    <script src="https://code.jquery.com/jquery-3.1.1.min.js"></script>
    <script src="http://malsup.github.com/jquery.form.js"></script> 
    <script src="assets/js/client.js"></script>

</body>

</html>